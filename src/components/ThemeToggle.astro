<button id="theme-toggle" class="ui" type="button" aria-label="Toggle color theme" aria-pressed="false">◐</button>
<style>
  #theme-toggle {
    background: none; border: 1px solid var(--rule); border-radius: 6px;
    color: var(--fg); cursor: pointer; font-size: 1rem; line-height: 1;
    padding: 0.35rem 0.5rem;
  }
</style>
<script is:inline>
  (function () {
    var KEY = 'theme';
    var root = document.documentElement;
    var btn = document.getElementById('theme-toggle');
    function current() {
      var dt = root.getAttribute('data-theme');
      if (dt === 'light' || dt === 'dark') return dt;
      return 'light'; // default to light unless the visitor has toggled dark
    }
    function sync() {
      if (btn) btn.setAttribute('aria-pressed', current() === 'dark' ? 'true' : 'false');
    }
    sync();
    btn && btn.addEventListener('click', function () {
      var next = current() === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem(KEY, next); } catch (e) {}
      sync();
    });
  })();
</script>
