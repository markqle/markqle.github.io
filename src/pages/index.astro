---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---
<BaseLayout title={site.title} description={site.description}>
  <section class="prose">
    <h1>{site.name}</h1>
    <!-- TODO(mark): tweak wording to taste -->
    <p>
      I'm a software and data engineer who likes turning messy problems into
      systems that actually work — across machine learning, computer vision,
      and data infrastructure.
    </p>
    <p>
      Lately I've been drawn to <strong>robotics</strong>, where those threads
      come together: perception, control, and getting software to behave
      reliably in the physical world. I build things, break them, and write
      about what I learn along the way.
    </p>
    <p class="muted">
      Explore my <a href="/projects">projects</a>, read the
      <a href="/blog">blog</a>, or view my <a href="/resume">resume</a>.
    </p>
  </section>
</BaseLayout>
