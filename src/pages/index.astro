---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { site } from '../data/site';
import portrait from '../assets/mark-yosemite.jpg';
---
<BaseLayout title={site.title} description={site.description}>
  <section class="prose">
    <h1>{site.name}</h1>
    <!-- TODO(mark): tweak wording to taste -->
    <p>
      I'm a software and data engineer who likes turning messy problems into
      systems that actually work, across machine learning, computer vision,
      and data infrastructure.
    </p>
    <p>
      Lately I've been drawn to <strong>robotics</strong>, where those threads
      come together: perception, control, and getting software to behave
      reliably in the physical world. I build things, break them, and write
      about what I learn along the way.
    </p>
    <p>
      Right now I'm freelancing, currently building a warehouse management
      system for a fertilizer trading company.
    </p>

    <figure class="portrait">
      <Image
        src={portrait}
        alt="Mark Le standing at Yosemite's Tunnel View, with El Capitan, Half Dome, and Bridalveil Fall behind."
        widths={[480, 800, 1200, 1600]}
        sizes="(max-width: 720px) 100vw, 720px"
        loading="eager"
      />
      <figcaption class="muted">Tunnel View, Yosemite National Park</figcaption>
    </figure>

    <p>
      Looking forward to having a coffee chat. My contact information is on
      the <a href="/resume">resume</a> page.
    </p>

    <p class="muted">
      Explore my <a href="/projects">projects</a>, read the
      <a href="/blog">blog</a>, or view my <a href="/resume">resume</a>.
    </p>
  </section>
</BaseLayout>
<style>
  .portrait { margin: var(--space-4) 0; }
  .portrait img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--rule);
  }
  .portrait figcaption {
    margin-top: var(--space-1);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    text-align: center;
  }
</style>
